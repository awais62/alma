# Required — fill in before running
LIVEKIT_URL=wss://your-livekit-server.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# AMD GPU server endpoints (set after AMD server is provisioned)
VLLM_BASE_URL=http://amd-gpu-server:8000/v1
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
WHISPER_BASE_URL=http://amd-gpu-server:8178
KOKORO_BASE_URL=http://amd-gpu-server:8880

# FastMCP server URL (set after mcp-server is deployed)
MCP_SERVER_URL=https://taible-mcp.fly.dev

# Restaurant config
RESTAURANT_SLUG=taible-bistro
LIVEKIT_ROOM=taible-demo
